# Ambiente
NODE_ENV=development

# URLs
BACKEND_URL=http://localhost
FRONTEND_URL=http://localhost:3000
PROXY_PORT=443
PORT=8080

# Banco de dados
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=whaticket
DB_PASS=whaticket123
DB_NAME=whaticket

# JWT
JWT_SECRET=your-super-secret-jwt-token
JWT_REFRESH_SECRET=your-super-secret-refresh-token

# Redis
REDIS_URI=redis://:whaticket123@localhost:6379
REDIS_OPT_LIMITER_MAX=1
REDIS_OPT_LIMITER_DURATION=3000

# Limites
USER_LIMIT=10000
CONNECTIONS_LIMIT=100000
CLOSED_SEND_BY_ME=true

# Gerencianet
GERENCIANET_SANDBOX=true
GERENCIANET_CLIENT_ID=your-client-id
GERENCIANET_CLIENT_SECRET=your-client-secret
GERENCIANET_PIX_CERT=your-pix-cert
GERENCIANET_PIX_KEY=your-pix-key

# AWS
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=your-region
AWS_S3_BUCKET=your-bucket

# Sentry
SENTRY_DSN=your-sentry-dsn

# Email
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-email
MAIL_PASS=your-password
MAIL_FROM=noreply@whaticket.com

# WhatsApp
WHATSAPP_API_URL=https://api.whatsapp.com/v1
WHATSAPP_API_KEY=your-api-key

# reCAPTCHA
RECAPTCHA_SECRET_KEY=your-secret-key
RECAPTCHA_SITE_KEY=your-site-key

# SSL
SSL_CERT_PATH=/etc/letsencrypt/live/whaticket.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/whaticket.com/privkey.pem

# Monitoramento
ENABLE_METRICS=true
METRICS_USERNAME=prometheus
METRICS_PASSWORD=prometheus123

# Cache
CACHE_DRIVER=redis
QUEUE_DRIVER=redis
SESSION_DRIVER=redis

# Logs
LOG_LEVEL=info
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7d 